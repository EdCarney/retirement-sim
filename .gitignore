# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Simulation output (charts)
output/

# Local SQLite database (user accounts + saved plans)
.data/

# Frontend
frontend/node_modules/
frontend/dist/

# Browser automation artifacts
.playwright-mcp/

